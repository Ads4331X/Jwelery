# Backend API URL.
# Leave unset in production if your API is served from the same domain
# (e.g. proxied via vercel.json rewrites or an .htaccess proxy on cPanel) —
# the app will default to same-origin automatically.
VITE_API_URL=http://localhost:5000

# Optional cookie domain for the customer auth cookie.
# Dev: leave unset (defaults to "localhost").
# Prod: leave unset too — it will default to your actual domain automatically.
# Only set this explicitly if you need the cookie shared across subdomains,
# e.g. VITE_COOKIE_DOMAIN=.yourdomain.com
# VITE_COOKIE_DOMAIN=